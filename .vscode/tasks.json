{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kill Ports",
      "type": "shell",
      "command": "foreach ($p in @(8080,5173,8000)) { $lines = netstat -ano | findstr \":$p\"; foreach ($line in $lines) { $parts = $line -split ' '; $processId = $parts[-1]; if ($processId -match '^[0-9]+$') { taskkill /PID $processId /F } } }",
      "problemMatcher": []
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": ".\\mvnw spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/carebridge-backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/carebridge-frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "ML Service",
      "type": "shell",
      "command": "uvicorn main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/ml-service"
      },
      "problemMatcher": []
    },
    {
      "label": "Run All",
      "dependsOn": ["Kill Ports", "Backend", "Frontend", "ML Service"],
      "dependsOrder": "parallel"
    }
  ]
}
 


